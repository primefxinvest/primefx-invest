# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Alias also supported: NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# Google sign-in (optional — enable in Supabase first)
# 1. Supabase Dashboard → Authentication → Providers → Google → Enable
# 2. Add Google Cloud OAuth Client ID + Secret in that same screen
# 3. Supabase → Authentication → URL Configuration:
#    Site URL: https://www.primefxinvest.com  (must match the domain users visit exactly)
#    Redirect URLs:
#    http://localhost:3000/auth/callback
#    https://www.primefxinvest.com/auth/callback
# 4. Google Cloud Console → OAuth client → Authorized redirect URIs:
#    https://<your-project-ref>.supabase.co/auth/v1/callback
# Set to false to hide Google buttons until the provider is configured
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Optional: Supabase Service Role — REQUIRED for admin portal data/actions
# Supabase → Project Settings → API → service_role (secret). NOT the anon/publishable key.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here

# Optional: Direct Postgres connection for maintenance scripts (financial reset, audits)
# Supabase → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or set SUPABASE_DB_PASSWORD and the audit script will build DATABASE_URL from NEXT_PUBLIC_SUPABASE_URL

# Bootstrap admin portal access (comma-separated) until admin_profiles is populated
# Platform owner: infojimvio@gmail.com | Full portal admin: fxinvestprime@gmail.com
ADMIN_SUPER_EMAILS=infojimvio@gmail.com,fxinvestprime@gmail.com

# AI — Google Gemini (required for PrimeAI)
# Free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional model override (default: gemini-flash-latest)
# GEMINI_CHAT_MODEL=gemini-flash-latest
# Alias also supported:
# GOOGLE_API_KEY=your_gemini_api_key_here
# GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Optional fallback for KYC document OCR only (PrimeAI does not use OpenAI)
# OPENAI_API_KEY=your_openai_api_key_here

# App Configuration (used for canonical URLs, sitemap, and Open Graph)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: set to your canonical origin (e.g. https://www.primefxinvest.com)
NODE_ENV=development

# Payment mode: sandbox | production
PAYMENT_MODE=sandbox
PAYMENT_WEBHOOK_BASE_URL=http://localhost:3000
PAYMENT_SUCCESS_REDIRECT_URL=http://localhost:3000/wallet?deposit=success
PAYMENT_CANCEL_REDIRECT_URL=http://localhost:3000/wallet?deposit=cancelled

# Binance Pay (API key + secret only — webhooks verified via Binance RSA certificates)
# In merchant admin, whitelist your server's outbound IP under API restrictions (error 400004 if missing).
BINANCE_PAY_API_KEY=
BINANCE_PAY_API_SECRET=
# Optional: timestamp tolerance for webhook verification (seconds, default 300)
# BINANCE_PAY_TIMESTAMP_TOLERANCE_SECONDS=300

# NOWPayments (NOWPAYMENTS_ENV overrides PAYMENT_MODE for this provider)
NOWPAYMENTS_ENV=production
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io
NOWPAYMENTS_JWT_TOKEN=
NOWPAYMENTS_EMAIL=
NOWPAYMENTS_PASSWORD=

# Didit identity verification
# DIDIT_API_KEY = application api_key from Didit dashboard (sent as x-api-key header)
# Docs: https://docs.didit.me/getting-started/api-authentication
DIDIT_API_KEY=
DIDIT_WEBHOOK_SECRET=
DIDIT_WORKFLOW_ID=
NEXT_VERIFICATION_BASE_URL=https://verification.didit.me
NEXT_PUBLIC_VERIFICATION_CALLBACK_URL=http://localhost:3000/verify/callback
# Didit webhook destination — canonical endpoint (register in Didit dashboard):
# https://www.primefxinvest.com/api/verify/webhook
# Legacy path /webhooks/didit rewrites to the canonical handler automatically.

# Cron jobs (weekly commissions, withdrawal queue) — set a strong secret in production
CRON_SECRET=
